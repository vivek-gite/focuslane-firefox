{
  "manifest_version": 2,
  "name": "focuslane",
  "version": "2.3.1",
  "description": "Make YouTube calm and intentional — block Shorts, hide the feed, filter videos, and stay on track. Includes SponsorBlock + Return YouTube Dislike. No data collected.",
  "permissions": [
    "storage",
    "tabs",
    "webRequest",
    "webRequestBlocking",
    "*://*.youtube.com/*",
    "https://video.google.com/*",
    "https://focuslane-api.onrender.com/*",
    "https://sponsor.ajay.app/*",
    "https://returnyoutubedislikeapi.com/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "focuslane",
    "default_icon": {
      "16": "icons/icon-toolbar-on-light.svg",
      "32": "icons/icon-toolbar-on-light.svg",
      "48": "icons/icon-toolbar-on-light.svg",
      "64": "icons/icon-toolbar-on-light.svg"
    },
    "theme_icons": [
      {
        "dark": "icons/icon-toolbar-on-light.svg",
        "light": "icons/icon-toolbar-on-dark.svg",
        "size": 16
      },
      {
        "dark": "icons/icon-toolbar-on-light.svg",
        "light": "icons/icon-toolbar-on-dark.svg",
        "size": 32
      },
      {
        "dark": "icons/icon-toolbar-on-light.svg",
        "light": "icons/icon-toolbar-on-dark.svg",
        "size": 48
      }
    ]
  },
  "icons": {
    "48": "icons/icon.svg",
    "96": "icons/icon.svg",
    "128": "icons/icon.svg"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "zen@focuslane",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  }
}
