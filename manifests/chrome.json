{
  "manifest_version": 3,
  "name": "focuslane",
  "version": "2.3.1",
  "description": "Make YouTube calm and intentional - block Shorts, hide the feed, filter videos, and stay on track. Includes SponsorBlock + Return YouTube Dislike. No data collected.",
  "permissions": [
    "storage",
    "tabs",
    "declarativeNetRequestWithHostAccess"
  ],
  "host_permissions": [
    "*://*.youtube.com/*",
    "https://video.google.com/*",
    "https://focuslane-api.onrender.com/*",
    "https://sponsor.ajay.app/*",
    "https://returnyoutubedislikeapi.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "focuslane",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
